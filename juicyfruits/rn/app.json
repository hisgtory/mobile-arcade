{
  "expo": {
    "name": "Juicy Fruits",
    "slug": "juicy-fruits",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon_v2.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon_v2.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hisgtory.juicyfruits"
    },
    "android": {
      "package": "com.hisgtory.juicyfruits",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon_v2.png",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode": "pan",
      "navigationBar": {
        "visible": "immersive"
      }
    },
    "web": {
      "favicon": "./assets/icon_v2.png"
    },
    "plugins": [
      [
        "expo-navigation-bar",
        {
          "visible": "immersive"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6129946475801358~3237973821",
          "iosAppId": "ca-app-pub-6129946475801358~9228667108"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ]
    ],
    "extra": {
      "expo-navigation-bar": {
        "visible": "immersive"
      },
      "eas": {
        "projectId": "d0434e5e-2f8d-4bbb-9389-61ef036b3a52"
      }
    },
    "owner": "hisgtory"
  },
  "react-native-google-mobile-ads": {
    "android_app_id": "ca-app-pub-6129946475801358~3237973821",
    "ios_app_id": "ca-app-pub-6129946475801358~9228667108"
  }
}
