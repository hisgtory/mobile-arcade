{
  "expo": {
    "name": "Found3",
    "slug": "found3",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arcade.found3"
    },
    "android": {
      "package": "com.arcade.found3",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode": "pan",
      "navigationBar": {
        "visible": "immersive"
      }
    },
    "plugins": [
      [
        "expo-navigation-bar",
        {
          "visible": "immersive"
        }
      ]
    ]
  }
}
