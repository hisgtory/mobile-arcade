# RN WebView Dev Server Host
#
# Platform defaults (no need to set for emulators/simulators):
#   Android emulator : 10.0.2.2   — loopback alias to host machine
#   iOS simulator    : localhost   — simulator shares host network
#
# Real device (WiFi): MUST set to your machine's local IP or hostname
# EXPO_PUBLIC_DEV_HOST=192.168.1.100
#
# Alternatively, use a Bonjour hostname (macOS only, requires mDNS support):
# EXPO_PUBLIC_DEV_HOST=your-mac.local
