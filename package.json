{
  "name": "mobile-arcade",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r typecheck",
    "lint": "node scripts/run-workspace-script.cjs lint",
    "test": "node scripts/run-workspace-script.cjs test",
    "dev:found3": "pnpm --filter @arcade/web-found3 dev",
    "build:found3": "pnpm --filter @arcade/web-found3 build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0"
  },
  "pnpm": {
    "overrides": {
      "typescript": "5.9.3",
      "vite": "5.4.21"
    },
    "onlyBuiltDependencies": [
      "@sentry/cli"
    ]
  }
}
